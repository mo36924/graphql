{
  "name": "@mo36924/graphql",
  "version": "2.0.1",
  "description": "",
  "keywords": [],
  "homepage": "https://github.com/mo36924/graphql#readme",
  "bugs": {
    "url": "https://github.com/mo36924/graphql/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mo36924/graphql.git"
  },
  "license": "MIT",
  "author": "mo36924",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.mjs",
      "require": "./dist/*.cjs",
      "default": "./dist/*.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts",
        "*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc -w",
    "build": "run-s clean test lint format build:*",
    "build:rollup": "rollup -c --configPlugin typescript",
    "clean": "del dist",
    "format": "run-s format:*",
    "format:sort-package-json": "sort-package-json",
    "format:prettier": "prettier --write .",
    "lint": "eslint --ext .ts --fix .",
    "test": "jest"
  },
  "prettier": {
    "printWidth": 120,
    "trailingComma": "all"
  },
  "eslintConfig": {
    "extends": [
      "@mo36924"
    ]
  },
  "jest": {
    "transform": {
      ".+\\.(t|j)sx?$": [
        "@swc/jest",
        {
          "module": {
            "type": "commonjs"
          }
        }
      ]
    }
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "change-case": "^4.1.2",
    "cosmiconfig": "^7.0.1",
    "diff": "^5.1.0",
    "graphql": "^16.5.0",
    "pluralize": "^8.0.0",
    "prettier": "^2.6.2"
  },
  "devDependencies": {
    "@mo36924/eslint-config": "^2.0.0",
    "@rollup/plugin-typescript": "^8.3.2",
    "@swc/core": "^1.2.194",
    "@swc/jest": "^0.2.21",
    "@types/diff": "^5.0.2",
    "@types/pluralize": "^0.0.29",
    "del-cli": "^4.0.1",
    "eslint": "^8.16.0",
    "jest": "^28.1.0",
    "npm-run-all": "^4.1.5",
    "rollup": "^2.74.1",
    "rollup-plugin-dts": "^4.2.2",
    "sort-package-json": "^1.57.0",
    "typescript": "^4.7.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
